{
  "info": {
    "name": "AGMS - Automated Greenhouse Management System",
    "description": "Complete API collection for the Automated Greenhouse Management System microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "External IoT API - Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"agms_user\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "http://104.211.95.241:8080/api/auth/register" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"agms_user\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "http://104.211.95.241:8080/api/auth/login" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": { "raw": "http://104.211.95.241:8080/api/auth/refresh" }
          }
        }
      ]
    },
    {
      "name": "Zone Management Service",
      "item": [
        {
          "name": "Create Zone",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tomato\",\n  \"minTemp\": 18.0,\n  \"maxTemp\": 32.0\n}"
            },
            "url": { "raw": "http://localhost:8080/api/zones" }
          }
        },
        {
          "name": "Get Zone by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/zones/1" }
          }
        },
        {
          "name": "Update Zone",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tomato-Updated\",\n  \"minTemp\": 20.0,\n  \"maxTemp\": 35.0\n}"
            },
            "url": { "raw": "http://localhost:8080/api/zones/1" }
          }
        },
        {
          "name": "Delete Zone",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/zones/1" }
          }
        }
      ]
    },
    {
      "name": "Sensor Telemetry Service",
      "item": [
        {
          "name": "Get Latest Reading",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/sensors/latest" }
          }
        }
      ]
    },
    {
      "name": "Automation & Control Service",
      "item": [
        {
          "name": "Process Sensor Data (Internal)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceId\": \"b751b8c9-644a-484c-ba3f-be63f9b27ad0\",\n  \"zoneId\": \"Zone-1\",\n  \"temperature\": 35.5,\n  \"humidity\": 60.2\n}"
            },
            "url": { "raw": "http://localhost:8080/api/automation/process" }
          }
        },
        {
          "name": "Get Automation Logs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/automation/logs" }
          }
        }
      ]
    },
    {
      "name": "Crop Inventory Service",
      "item": [
        {
          "name": "Create Crop Batch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cropName\": \"Cherry Tomato\",\n  \"zoneId\": \"Zone-Tomato\",\n  \"quantity\": 200\n}"
            },
            "url": { "raw": "http://localhost:8080/api/crops" }
          }
        },
        {
          "name": "Update Crop Status (SEEDLING -> VEGETATIVE)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/crops/1/status?status=VEGETATIVE" }
          }
        },
        {
          "name": "Update Crop Status (VEGETATIVE -> HARVESTED)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/crops/1/status?status=HARVESTED" }
          }
        },
        {
          "name": "Get All Crops",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
            ],
            "url": { "raw": "http://localhost:8080/api/crops" }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwtToken",
      "value": "your-jwt-token-here"
    },
    {
      "key": "refreshToken",
      "value": "your-refresh-token-here"
    }
  ]
}
